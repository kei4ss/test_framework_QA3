{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JSONPlaceholder User",
  "type": "object",
  "required": ["id", "username", "name", "email", "password"],
  "properties": {
    "id": {
      "type": "integer"
    },
    "name": {
      "type": "object",
      "properties": {
        "firstname": {
          "type":"string"
        },
        "lastname": {
          "type":"string"
        }
      }
    },
    "username": {
      "type": "string"
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "password":{
      "type":"string"
    }
  },
  "additionalProperties": true
}
